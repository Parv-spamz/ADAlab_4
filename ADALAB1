# TASK 4 – Recurrence Relations
# =================================================

def recurrence1(n):
    if n <= 1:
        return 1
    return recurrence1(n // 2) + n


def recurrence2(n):
    if n <= 1:
        return 1
    return recurrence2(n // 2) + recurrence2(n // 2) + n


def run_task4():
    sizes = [16, 32, 64]
    time_results = {"T(n)=T(n/2)+n": [], "T(n)=2T(n/2)+n": []}
    space_results = {"T(n)=T(n/2)+n": [], "T(n)=2T(n/2)+n": []}

    for n in sizes:
        t1, m1 = profile(recurrence1, n)
        t2, m2 = profile(recurrence2, n)

        time_results["T(n)=T(n/2)+n"].append(t1)
        space_results["T(n)=T(n/2)+n"].append(m1)

        time_results["T(n)=2T(n/2)+n"].append(t2)
        space_results["T(n)=2T(n/2)+n"].append(m2)

    # Time Graph
    plt.figure()
    for name in time_results:
        plt.plot(sizes, time_results[name], label=name)
    plt.title("Task 4 - Time Complexity (Recurrence)")
    plt.xlabel("n")
    plt.ylabel("Time (seconds)")
    plt.legend()
    plt.grid()
    plt.show()

    # Space Graph
    plt.figure()
    for name in space_results:
        plt.plot(sizes, space_results[name], label=name)
    plt.title("Task 4 - Space Complexity (Recurrence)")
